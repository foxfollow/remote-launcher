# Test VM image for remote-launcher.
# Ubuntu with sshd + a test user whose authorized_keys is baked in at build.
# The pubkey is passed in via build-arg.

FROM ubuntu:24.04

ARG SSH_PUBKEY
ARG TEST_USER=testuser

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        openssh-server \
        sudo \
        ca-certificates \
        iproute2 \
        procps \
        less \
        curl && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash -G sudo "$TEST_USER" && \
    echo "$TEST_USER ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/90-testuser && \
    chmod 440 /etc/sudoers.d/90-testuser && \
    mkdir -p /home/$TEST_USER/.ssh && \
    echo "$SSH_PUBKEY" > /home/$TEST_USER/.ssh/authorized_keys && \
    chmod 700 /home/$TEST_USER/.ssh && \
    chmod 600 /home/$TEST_USER/.ssh/authorized_keys && \
    chown -R "$TEST_USER:$TEST_USER" /home/$TEST_USER/.ssh

# sshd hardening for tests:
# - PasswordAuthentication no  → only key auth
# - PermitRootLogin no
# - AcceptEnv (default empty)  → no env forwarding by default
RUN mkdir -p /var/run/sshd && \
    sed -i \
      -e 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' \
      -e 's/^#\?PermitRootLogin.*/PermitRootLogin no/' \
      -e 's/^#\?PubkeyAuthentication.*/PubkeyAuthentication yes/' \
      -e 's/^#\?ChallengeResponseAuthentication.*/ChallengeResponseAuthentication no/' \
      /etc/ssh/sshd_config && \
    ssh-keygen -A

EXPOSE 22

CMD ["/usr/sbin/sshd", "-D", "-e"]
