#!/usr/bin/env bash
# ssh-shell — CLAUDE_CODE_SHELL wrapper.
# Forwards every Bash tool invocation to $VM_REMOTE_HOST via SSH,
# preserving working directory between calls (per-session).
#
# Required env (set by remote-launcher):
#   VM_REMOTE_HOST       — ssh destination (e.g. "user@vm" or alias from ~/.ssh/config)
#   VM_REMOTE_SESSION    — unique id per remote-launcher invocation
#
# Optional env:
#   VM_SSH_OPTS          — extra ssh options, space-separated (used by tests for -F config-file)
#   VM_REMOTE_SHELL      — posix | powershell | auto (default: auto). When auto, the
#                          first call probes the host and caches the result for the session.
#   VM_REMOTE_PS_EXE     — pwsh | powershell (default: pwsh, falling back to powershell).
#                          Only consulted when VM_REMOTE_SHELL=powershell.
#
# Notes:
# - Uses SSH ControlMaster for connection reuse.
# - Tracks remote cwd via a tmpfile on the VM; cats it after every command.
# - Does NOT forward SSH agent (no -A).
# - Does NOT use SendEnv (no env vars cross to remote unless explicitly forwarded).

set -uo pipefail

# CRITICAL: break recursion before doing anything else.
# Claude Code sets $SHELL to this wrapper so the Bash tool inherits it.
# But SSH's ProxyCommand mechanism reads $SHELL to spawn the tunnel command
# (`ssh -W host:port jumphost`). If $SHELL still points at us, every
# ProxyJump invocation re-enters ssh-shell, opens another SSH back to the
# same target, which itself does ProxyJump → infinite recursion. The remote
# sshd hits MaxStartups and starts dropping connections, surfacing as
# `kex_exchange_identification: Connection closed by remote host`.
export SHELL=/bin/sh

: "${VM_REMOTE_HOST:?ssh-shell: VM_REMOTE_HOST not set; launch via remote-launcher}"
SESSION_ID="${VM_REMOTE_SESSION:-default}"

STATE_DIR="${TMPDIR:-/tmp}/remote-launcher-${SESSION_ID}"
mkdir -p "$STATE_DIR"

# Debug log captures ssh stderr + invocation context whenever a bootstrap or
# command call fails. Enabled by default; the file is overwritten per session.
DEBUG_LOG="$STATE_DIR/ssh-shell.log"
log_invocation() {
  {
    echo "===== $(date '+%Y-%m-%d %H:%M:%S') ssh-shell invocation ====="
    echo "PID=$$  PPID=$PPID"
    echo "ARGS: $*"
    echo "PWD=$(pwd)"
    echo "HOME=${HOME:-<unset>}"
    echo "SSH_AUTH_SOCK=${SSH_AUTH_SOCK:-<unset>}"
    echo "TMPDIR=${TMPDIR:-<unset>}"
    echo "VM_REMOTE_SHELL=${VM_REMOTE_SHELL:-<unset>}"
    echo "VM_REMOTE_PS_EXE=${VM_REMOTE_PS_EXE:-<unset>}"
  } >> "$DEBUG_LOG" 2>/dev/null || true
}
log_invocation "$@"

CWD_FILE="$STATE_DIR/cwd"
SHELL_MODE_FILE="$STATE_DIR/shell-mode"
PS_EXE_FILE="$STATE_DIR/ps-exe"

# ControlPath has to be SHORT — Unix sockets cap at ~104 chars on macOS, and
# OpenSSH appends a ~17-char random suffix. macOS $TMPDIR (~49 chars) plus our
# session dir blows past the limit. Park the socket under ~/.ssh/ (already 0700,
# already short).
SOCK_DIR="$HOME/.ssh"
mkdir -p "$SOCK_DIR"
SSH_CTL="$SOCK_DIR/rl-${SESSION_ID}.s"
REMOTE_PWD_BASENAME=".remote-launcher-cwd-${SESSION_ID}"
REMOTE_PWD_FILE_POSIX="/tmp/${REMOTE_PWD_BASENAME}"

SSH_OPTS=(
  -o "ControlMaster=auto"
  -o "ControlPath=$SSH_CTL"
  -o "ControlPersist=15m"
  -o "BatchMode=yes"
  -o "StrictHostKeyChecking=accept-new"
  -o "ServerAliveInterval=30"
  -o "ServerAliveCountMax=3"
  -T
)

# Append optional extra SSH options (used by tests, advanced users)
if [[ -n "${VM_SSH_OPTS:-}" ]]; then
  read -ra _EXTRA <<< "$VM_SSH_OPTS"
  SSH_OPTS+=("${_EXTRA[@]}")
  unset _EXTRA
fi

# ---------- Shell-mode resolution ----------
# Order of precedence:
#   1. Cached value in $SHELL_MODE_FILE (set during this session's first call)
#   2. VM_REMOTE_SHELL env var (posix | powershell | auto)
#   3. Default: auto (probe on first call)
SHELL_MODE=""
PS_EXE=""

if [[ -s "$SHELL_MODE_FILE" ]]; then
  SHELL_MODE=$(<"$SHELL_MODE_FILE")
  [[ -s "$PS_EXE_FILE" ]] && PS_EXE=$(<"$PS_EXE_FILE")
fi

if [[ -z "$SHELL_MODE" ]]; then
  case "${VM_REMOTE_SHELL:-auto}" in
    posix|powershell|auto) SHELL_MODE="${VM_REMOTE_SHELL:-auto}" ;;
    *)
      echo "ssh-shell: invalid VM_REMOTE_SHELL='${VM_REMOTE_SHELL}' (expected posix|powershell|auto)" >&2
      exit 2
      ;;
  esac
fi

if [[ "$SHELL_MODE" == "powershell" && -z "$PS_EXE" ]]; then
  PS_EXE="${VM_REMOTE_PS_EXE:-pwsh}"
fi

probe_posix() {
  ssh "${SSH_OPTS[@]}" "$VM_REMOTE_HOST" "/bin/sh -c 'echo __posix_ok__'" 2>>"$DEBUG_LOG"
}

probe_ps() {
  # $1 = pwsh|powershell
  ssh "${SSH_OPTS[@]}" "$VM_REMOTE_HOST" "$1 -NoProfile -Command \"Write-Output __ps_ok__\"" 2>>"$DEBUG_LOG"
}

# Bootstrap: resolve $HOME on the VM if we don't have a cwd yet.
# Capture ssh stderr to the debug log so failures inside Claude Code surface
# the actual SSH error (Claude only shows our wrapper's tail).
if [[ ! -s "$CWD_FILE" ]]; then
  echo "--- bootstrap ssh stderr ---" >> "$DEBUG_LOG" 2>/dev/null || true

  bootstrap_failed=0

  # Auto-detect if requested.
  if [[ "$SHELL_MODE" == "auto" ]]; then
    out=$(probe_posix || true)
    if [[ "$out" == *"__posix_ok__"* ]]; then
      SHELL_MODE=posix
    else
      for cand in pwsh powershell; do
        out=$(probe_ps "$cand" || true)
        if [[ "$out" == *"__ps_ok__"* ]]; then
          SHELL_MODE=powershell
          PS_EXE="$cand"
          break
        fi
      done
    fi
    if [[ "$SHELL_MODE" == "auto" ]]; then
      bootstrap_failed=1
    fi
  fi

  if [[ "$bootstrap_failed" -eq 0 ]]; then
    if [[ "$SHELL_MODE" == "powershell" ]]; then
      # PowerShell: $HOME is an automatic variable on both Windows PS 5.1 and pwsh 7+.
      CWD_RAW=$(ssh "${SSH_OPTS[@]}" "$VM_REMOTE_HOST" "$PS_EXE -NoProfile -Command \"Write-Output \$HOME\"" 2>>"$DEBUG_LOG") || bootstrap_failed=1
      CWD_RAW=$(printf '%s' "$CWD_RAW" | tr -d '\r' | head -n1)
    else
      CWD_RAW=$(ssh "${SSH_OPTS[@]}" "$VM_REMOTE_HOST" "/bin/sh -c 'echo \$HOME'" 2>>"$DEBUG_LOG") || bootstrap_failed=1
    fi
    [[ -z "$CWD_RAW" ]] && bootstrap_failed=1
  fi

  if [[ "$bootstrap_failed" -ne 0 ]]; then
    {
      echo "ssh-shell: cannot connect to $VM_REMOTE_HOST"
      echo "ssh-shell: shell mode = ${SHELL_MODE:-<unresolved>}${PS_EXE:+ ($PS_EXE)}"
      echo "ssh-shell: debug log → $DEBUG_LOG"
      echo "--- last 30 lines of ssh stderr ---"
      tail -n 30 "$DEBUG_LOG" 2>/dev/null
    } >&2
    exit 255
  fi

  printf '%s\n' "$CWD_RAW" > "$CWD_FILE"
  printf '%s\n' "$SHELL_MODE" > "$SHELL_MODE_FILE"
  [[ -n "$PS_EXE" ]] && printf '%s\n' "$PS_EXE" > "$PS_EXE_FILE"
fi

CWD=$(<"$CWD_FILE")
[[ -z "$CWD" ]] && CWD='$HOME'

# Parse args bash-style. Claude Code 2.1.x invokes the shell as
# `<shell> -c -l <cmd>` (-c first, then -l, then the command string).
# Real bash treats -c, -l, --login etc. as independent flags in any order,
# and the command for -c is the next non-flag positional. Replicate that.
CMD=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c)
      shift
      # skip any further flags (-l, --login, --noprofile, etc.)
      while [[ $# -gt 0 && "$1" == -* ]]; do shift; done
      CMD="${1:-}"
      break
      ;;
    -l|--login|--noprofile|--norc|-i)
      shift
      ;;
    --version)
      # Claude probes shells with `--version` to check they're real bash/zsh.
      exec bash --version
      ;;
    *)
      CMD="$*"
      break
      ;;
  esac
done

# Empty command → no-op (Claude sometimes probes the shell at startup)
if [[ -z "$CMD" ]]; then
  exit 0
fi

if [[ "$SHELL_MODE" == "powershell" ]]; then
  # ---------- PowerShell execution path ----------
  # Claude Code's Bash tool ALWAYS wraps the model's command in a bash prelude:
  #   shopt -u extglob 2>/dev/null || true && eval '<inner>' < /dev/null && pwd -P >| /tmp/claude-<hash>-cwd
  # That's bash syntax — PowerShell can't parse it (no ||, &&, <, >|). Strip the
  # wrapper to extract <inner> (the actual command the model wrote), un-escape
  # bash's '\''-style single-quote escapes, and run that as PowerShell. We
  # ignore the embedded `pwd -P > /tmp/claude-…-cwd` cwd-capture because we
  # have our own cwd round-trip below.
  if [[ "$CMD" == "shopt -u extglob 2>/dev/null || true && eval '"* ]]; then
    inner="${CMD#shopt -u extglob 2>/dev/null || true && eval \'}"
    inner="${inner%\' < /dev/null && pwd -P >| /tmp/claude-*-cwd}"
    # Un-escape bash's '\''-style single-quote escapes back to '
    inner="${inner//\'\\\'\'/\'}"
    CMD="$inner"
  fi

  # The user's $CMD is now PowerShell syntax (the prompt tells the model the
  # host is PS). We embed it into a wrapper that:
  #   - cds into the cached working directory
  #   - resets $LASTEXITCODE so a clean cmdlet path returns 0
  #   - runs the user's command inside try/catch so terminating errors → exit 1
  #   - writes the new cwd to a file we read back via a separate ssh hop
  #
  # Quoting: $CWD is embedded into a single-quoted PS string with '' escaping.
  # $CMD is interpolated raw — it's already PS and may contain $, ', ".
  CWD_PS=$(printf '%s' "$CWD" | sed "s/'/''/g")
  PS_SCRIPT=$(cat <<PSEOF
\$ErrorActionPreference = 'Continue'
try { Set-Location -LiteralPath '$CWD_PS' -ErrorAction Stop } catch { Set-Location \$HOME }
\$LASTEXITCODE = 0
\$__ec = 0
try {
$CMD
    \$__ec = \$LASTEXITCODE
} catch {
    Write-Error \$_
    \$__ec = 1
}
(Get-Location).Path | Out-File -Encoding ASCII -FilePath (Join-Path \$env:TEMP '$REMOTE_PWD_BASENAME')
exit \$__ec
PSEOF
)
  # PowerShell -EncodedCommand expects UTF-16LE base64. macOS ships iconv.
  PS_B64=$(printf '%s' "$PS_SCRIPT" | iconv -t UTF-16LE | base64 | tr -d '\n')

  ssh "${SSH_OPTS[@]}" "$VM_REMOTE_HOST" "$PS_EXE -NoProfile -EncodedCommand $PS_B64"
  EC=$?

  NEW_CWD=$(ssh "${SSH_OPTS[@]}" "$VM_REMOTE_HOST" \
    "$PS_EXE -NoProfile -Command \"Get-Content -Raw (Join-Path \$env:TEMP '$REMOTE_PWD_BASENAME')\"" \
    2>/dev/null | tr -d '\r' | tr -d '\n' || true)
else
  # ---------- POSIX execution path ----------
  # Build the remote script and base64-encode it so the remote login shell
  # (tcsh on OPNsense/FreeBSD, dash, etc.) never interprets the syntax.
  # We always exec /bin/sh explicitly on the far end.
  REMOTE_SCRIPT="cd '$CWD' 2>/dev/null || cd \$HOME
$CMD
__EC=\$?
pwd > '$REMOTE_PWD_FILE_POSIX' 2>/dev/null
exit \$__EC"

  SCRIPT_B64=$(printf '%s\n' "$REMOTE_SCRIPT" | base64 | tr -d '\n')

  ssh "${SSH_OPTS[@]}" "$VM_REMOTE_HOST" "/bin/sh -c 'printf %s $SCRIPT_B64 | base64 -d | /bin/sh'"
  EC=$?

  # Pull updated cwd back. ControlMaster makes this cheap.
  # Wrap in /bin/sh so tcsh (OPNsense/FreeBSD) doesn't misparse 2>/dev/null.
  NEW_CWD=$(ssh "${SSH_OPTS[@]}" "$VM_REMOTE_HOST" "/bin/sh -c 'cat $REMOTE_PWD_FILE_POSIX 2>/dev/null'" 2>/dev/null || true)
fi

if [[ -n "$NEW_CWD" ]]; then
  printf '%s\n' "$NEW_CWD" > "$CWD_FILE"
fi

exit $EC
