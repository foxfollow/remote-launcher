#!/usr/bin/env bash
# remote-launcher-doctor — sanity-check installation and SSH reachability.
#
# Usage:
#   remote-launcher-doctor                # files / PATH only
#   remote-launcher-doctor <ssh-host>     # also live SSH + wrapper round-trip

set -uo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: remote-launcher-doctor [<ssh-host>]"
  echo "  No args  — file/setup checks only"
  echo "  <host>   — also runs live SSH + ssh-shell round-trip against that host"
  echo "  -v|--version — print version"
  exit 0
fi

SELF="${BASH_SOURCE[0]}"
while [[ -L "$SELF" ]]; do SELF=$(readlink "$SELF"); done
SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PROJECT_DIR="$(cd "$SELF_DIR/.." && pwd)"

RL_VERSION="$(tr -d '[:space:]' < "$PROJECT_DIR/VERSION" 2>/dev/null || true)"
RL_VERSION="${RL_VERSION:-unknown}"

if [[ "${1:-}" == "-v" || "${1:-}" == "--version" ]]; then
  echo "remote-launcher-doctor $RL_VERSION"
  exit 0
fi

echo "remote-launcher-doctor (v$RL_VERSION)"

PASS=0; FAIL=0
ok()   { echo "  ✅ $1"; PASS=$((PASS+1)); }
fail() { echo "  ❌ $1"; FAIL=$((FAIL+1)); }

echo "== file/setup checks =="
[[ -d "$PROJECT_DIR" ]]                    && ok "project at $PROJECT_DIR" || fail "project dir missing"
[[ -x "$PROJECT_DIR/bin/ssh-shell" ]]      && ok "ssh-shell executable"    || fail "ssh-shell missing/non-exec"
[[ -L "$PROJECT_DIR/bin/ssh-shell-bash" && -x "$PROJECT_DIR/bin/ssh-shell-bash" ]] \
  && ok "ssh-shell-bash symlink (Claude requires 'bash' in shell path)" \
  || fail "ssh-shell-bash symlink missing — Claude won't honor CLAUDE_CODE_SHELL"
[[ -x "$PROJECT_DIR/bin/remote-launcher" ]] && ok "remote-launcher executable" || fail "remote-launcher missing/non-exec"
[[ -f "$PROJECT_DIR/prompts/REMOTE_PROMPT.md" ]] && ok "REMOTE_PROMPT.md present" || fail "REMOTE_PROMPT.md missing"
[[ -f "$PROJECT_DIR/skill/SKILL.md" ]]     && ok "SKILL.md present"        || fail "SKILL.md missing"

# remote-launcher just needs to be reachable on PATH — either via install.sh
# (~/.local/bin symlink) or Homebrew (/opt/homebrew/bin). Accept any of them.
if RL_ON_PATH=$(command -v remote-launcher 2>/dev/null); then
  ok "remote-launcher on PATH ($RL_ON_PATH)"
elif [[ -L "$HOME/.local/bin/remote-launcher" || -x "$HOME/.local/bin/remote-launcher" ]]; then
  ok "~/.local/bin/remote-launcher in place (not on PATH yet)"
else
  fail "remote-launcher NOT on PATH — run install.sh or 'brew install foxfollow/stone/remote-launcher'"
fi
command -v claude >/dev/null && ok "claude in PATH" || fail "claude not in PATH"
command -v ssh    >/dev/null && ok "ssh in PATH"    || fail "ssh not in PATH"

if [[ $# -ge 1 ]]; then
  HOST="$1"
  echo
  echo "== live SSH + wrapper test against $HOST =="

  if ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new "$HOST" 'echo ok' >/dev/null 2>&1; then
    ok "ssh $HOST 'echo ok'"
  else
    fail "ssh to $HOST (BatchMode, key auth)"
    echo "Summary: $PASS passed, $FAIL failed"; exit 1
  fi

  SESSION_ID="doctor-$$"
  out=$(VM_REMOTE_HOST="$HOST" VM_REMOTE_SESSION="$SESSION_ID" \
        "$PROJECT_DIR/bin/ssh-shell" -c 'echo "hostname=$(hostname); pwd=$(pwd)"')
  if [[ "$out" == hostname=* ]]; then
    ok "ssh-shell wrapper round-trip: $out"
  else
    fail "ssh-shell round-trip — unexpected output: $out"
  fi

  out2=$(VM_REMOTE_HOST="$HOST" VM_REMOTE_SESSION="$SESSION_ID" \
         "$PROJECT_DIR/bin/ssh-shell" -c 'cd /tmp && pwd')
  out3=$(VM_REMOTE_HOST="$HOST" VM_REMOTE_SESSION="$SESSION_ID" \
         "$PROJECT_DIR/bin/ssh-shell" -c 'pwd')
  if [[ "$out2" == "/tmp" && "$out3" == "/tmp" ]]; then
    ok "cwd persistence (cd /tmp; pwd → /tmp)"
  else
    fail "cwd not persisting (got '$out2' then '$out3')"
  fi

  rm -rf "${TMPDIR:-/tmp}/remote-launcher-${SESSION_ID}"
fi

echo
echo "Summary: $PASS passed, $FAIL failed"
[[ $FAIL -eq 0 ]] && exit 0 || exit 1
